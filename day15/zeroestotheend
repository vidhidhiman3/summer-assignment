#include <stdio.h>

int main() {
    int arr[] = {1, 0, 2, 0, 3, 4, 0};
    int n = 7;
    int j = 0;

    
    for (int i = 0; i < n; i++) {
        if (arr[i] != 0) {
            arr[j] = arr[i];
            j++;
        }
    }

    
    while (j < n) {
        arr[j] = 0;
        j++;
    }

    printf("Array after moving zeroes to end: ");

    for (int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}
