#include <stdio.h>
#include <string.h>

int palindrome(char s[])
{
    int i, j;

    for(i = 0, j = strlen(s) - 1; i < j; i++, j--)
    {
        if(s[i] != s[j])
            return 0;
    }
    return 1;
}

int main()
{
    char s[20];

    scanf("%s", s);

    if(palindrome(s))
        printf("Palindrome");
    else
        printf("Not Palindrome");

    return 0;
}
