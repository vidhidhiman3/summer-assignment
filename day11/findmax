#include <stdio.h>

int findMax(int num1, int num2);

int main()
{
    int a, b, maximum;

    printf("Enter first number: ");
    scanf("%d", &a);

    printf("Enter second number: ");
    scanf("%d", &b);

    maximum = findMax(a, b);

    printf("The maximum number between %d and %d is %d\n",
           a, b, maximum);

    return 0;
}

int findMax(int num1, int num2)
{
    return (num1 > num2) ? num1 : num2;
}
