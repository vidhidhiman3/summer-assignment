#include <stdio.h>

int main() {
    int a[] = {1, 2, 3};
    int b[] = {3, 4, 5};
    int i, j;

    printf("Intersection: ");

    for(i = 0; i < 3; i++) {
        for(j = 0; j < 3; j++) {
            if(a[i] == b[j]) {
                printf("%d ", a[i]);
            }
        }
    }

    return 0;
}
