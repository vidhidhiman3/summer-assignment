#include<stdio.h>
int main()
{
    int n,c,a=0,b=1,i;
    printf("Enter the term:");
    scanf("%d",&n);

    if(n==1){
        printf("fibonacci nth term=%d :",a);
    }
        else if(n==2)
        {
        printf("fibonacci nth term=%d",b);
        }
        else
        {
            for(i=3;i<=n;i++)
            {
                c=a+b;
                a=b;
                b=c;
            }
            printf("fibonacci nth term =%d",c);
        }
    return 0;
}
